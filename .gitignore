## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/lib/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb][Uu][Ii][Ll][Dd][Ll][Oo][Gg].*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Coverage Results
*.gpge
*.covxml
*.coverage
*.coveragexml

# MyGet
pkgs/

# Entity Framework 6+ (Nisquire)
*.EF6.db

# Entity Framework Core
# Migrations and context are usually committed, but let's exclude specific DBs
*.db
*.db-shm
*.db-wal

# SQL Server files
*.mdf
*.ldf
*.ndf

# Business Intelligence projects
*.rdl.data
*.bim.layout
*.bim_*.settings
*.rptproj.bak

# Microsoft Azure Build Output
csx/
*.build.csdef

# Azure Stream Analytics
ASATemp/

# Worker Role Microsoft Azure
filenames.txt

# Others
*.[Cc]ache
!*.[Gg][Cc][Cc]ache
ClientBin/
~$*
*~
*.dbmdl
*.dbproj.schemaview
*.jfm
*.pfx
*.publishsettings
orleans.codegenerator.cs

# Including Python build artifacts (for any scripts)
*.pyc
__pycache__/

# JetBrains
.idea/
*.sln.DotSettings.user

# Visual Studio Code
.vscode/
! .vscode/settings.json
! .vscode/tasks.json
! .vscode/launch.json
! .vscode/extensions.json
! .vscode/code-snippets

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docker
.dockerignore
# Unless you want to exclude specific docker images
# (But typically you commit the Dockerfile and docker-compose.yml)

# OS Files
.DS_Store
Thumbs.db

# Environment Variables (Sensitive Data)
.env
.env.local
.env.*.local
